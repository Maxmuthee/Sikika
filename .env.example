# Copy to .env and fill in. NEVER commit the real .env.
# Sikika uses the OpenAI SDK pointed at DeepSeek's OpenAI-compatible API.
SIKIKA_API_KEY=sk-...            # your DeepSeek API key
SIKIKA_BASE_URL=https://api.deepseek.com
SIKIKA_MODEL=deepseek-chat       # or deepseek-reasoner for heavier reasoning
